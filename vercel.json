{
  "version": 2,
  "rewrites": [
    { "source": "/auth",                  "destination": "_lib/api/index.js" },
    { "source": "/chatbot",               "destination": "_lib/api/index.js" },
    { "source": "/auth(.*)",              "destination": "_lib/api/index.js" },
    { "source": "/chatbot(.*)",           "destination": "_lib/api/index.js" },
    { "source": "/webhooks",              "destination": "_lib/api/index.js" },
    { "source": "/webhooks(.*)",          "destination": "_lib/api/index.js" },
    { "source": "/webhook",               "destination": "_lib/api/index.js" },
    { "source": "/webhook(.*)",           "destination": "_lib/api/index.js" },
    { "source": "/register-webhook",      "destination": "_lib/api/index.js" },
    { "source": "/register-webhook(.*)",  "destination": "_lib/api/index.js" },
    { "source": "/sync-catalog",          "destination": "_lib/api/index.js" },
    { "source": "/sync-catalog(.*)",      "destination": "_lib/api/index.js" },
    { "source": "/platform-settings",     "destination": "_lib/api/index.js" },
    { "source": "/platform-settings(.*)", "destination": "_lib/api/index.js" },
    { "source": "/setup",                 "destination": "_lib/api/index.js" },
    { "source": "/setup(.*)",             "destination": "_lib/api/index.js" },
    { "source": "/test-suri",             "destination": "_lib/api/index.js" },
    { "source": "/test-suri(.*)",         "destination": "_lib/api/index.js" },
    { "source": "/test-ecommerce",        "destination": "_lib/api/index.js" },
    { "source": "/test-ecommerce(.*)",    "destination": "_lib/api/index.js" },
    { "source": "/users",                 "destination": "_lib/api/index.js" },
    { "source": "/users(.*)",             "destination": "_lib/api/index.js" },
    { "source": "/integrations",          "destination": "_lib/api/index.js" },
    { "source": "/integrations(.*)",      "destination": "_lib/api/index.js" },
    { "source": "/notifications",         "destination": "_lib/api/index.js" },
    { "source": "/notifications(.*)",     "destination": "_lib/api/index.js" },
    { "source": "/sync-rules",            "destination": "_lib/api/index.js" },
    { "source": "/sync-rules(.*)",        "destination": "_lib/api/index.js" },
    { "source": "/(.*)",                  "destination": "/index.html" }
  ],
  "functions": {
    "api/index.js": {
      "maxDuration": 300
    }
  }
}
