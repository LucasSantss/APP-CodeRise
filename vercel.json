{
  "version": 2,
  "rewrites": [
    {
      "source": "/users",
      "destination": "/_lib/api/users.js"
    },
    {
      "source": "/users(.*)",
      "destination": "/_lib/api/users.js"
    },
    {
      "source": "/integrations",
      "destination": "/_lib/api/integrations.js"
    },
    {
      "source": "/integrations(.*)",
      "destination": "/_lib/api/integrations.js"
    },
    {
      "source": "/sync-rules",
      "destination": "/_lib/api/sync-rules.js"
    },
    {
      "source": "/sync-rules(.*)",
      "destination": "/_lib/api/sync-rules.js"
    },
    {
      "source": "/notifications",
      "destination": "/_lib/api/notifications.js"
    },
    {
      "source": "/notifications(.*)",
      "destination": "/_lib/api/notifications.js"
    },
    {
      "source": "/auth",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/auth(.*)",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/chatbot",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/chatbot(.*)",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/webhooks",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/webhooks(.*)",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/webhook",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/webhook(.*)",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/register-webhook",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/register-webhook(.*)",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/queue",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/queue(.*)",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/cleanup",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/cleanup(.*)",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/setup",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/setup(.*)",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/test-suri",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/test-suri(.*)",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/test-ecommerce",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/test-ecommerce(.*)",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/platform-settings",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/platform-settings(.*)",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/sync-catalog",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/sync-catalog(.*)",
      "destination": "/_lib/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "functions": {
    "_lib/api/index.js": {
      "maxDuration": 300
    },
    "_lib/api/users.js": {
      "maxDuration": 30
    },
    "_lib/api/integrations.js": {
      "maxDuration": 30
    },
    "_lib/api/notifications.js": {
      "maxDuration": 30
    },
    "_lib/api/sync-rules.js": {
      "maxDuration": 30
    }
  },
  "crons": [
    {
      "path": "/queue/process",
      "schedule": "0 * * * *"
    },
    {
      "path": "/cleanup",
      "schedule": "0 3 * * *"
    }
  ]
}