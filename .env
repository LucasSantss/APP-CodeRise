# ── Banco de dados (NÃO é exposto ao frontend) ────────────────────────────────
# Cole aqui a URL de conexão POOLED do Neon (com -pooler no hostname)
DATABASE_URL=

# ── URL da API (exposta ao frontend via VITE_) ────────────────────────────────
# Para desenvolvimento local com vercel dev, deixe vazio.
# Para produção separada (front e back em projetos diferentes),
# coloque a URL do back-end: https://seu-backend.vercel.app
VITE_API_URL=
